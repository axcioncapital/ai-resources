# OS artifacts
.DS_Store
*.swp
*~

# Sensitive files
*.env
.env.*
credentials*.json
*.key
*.pem

# IDE
.idea/
.vscode/

# Local-only Claude Code settings (operator overrides, not shared)
.claude/settings.local.json

# Python
__pycache__/
*.pyc

# Ephemeral audit working notes (subagent-contract discipline lives in CLAUDE.md, not as a deny rule)
audits/working/

# Ephemeral session scratchpads (/save-session outputs, implementation plans — lasting content graduates to session-notes or decisions.md)
logs/scratchpads/

# Concurrent-session detection marker written by /prime, read by /session-start Step 0.5
logs/.prime-mtime

# Per-session identity marker written by /prime (Phase 1 of TOCTOU-mitigation rollout per logs/improvement-log.md TOCTOU entry)
logs/.session-marker
# Per-session-id identity oracle (Option 2′, keyed by CLAUDE_CODE_SESSION_ID — un-clobberable by a concurrent /prime; see docs/session-marker.md)
logs/.session-marker-*

# Archived inbox briefs (Layer C settings.json also denies Read on this path)
inbox/archive/

# Top-level archive directory only (anchored 2026-07-03 — the unanchored form silently ignored
# nested archive dirs, notably logs/missions/archive/, forcing `git add -f` on mission-close
# records; Layer C settings.json also denies Read on this top-level path)
/archive/

# Context-engine runtime output (packs are session artifacts; treated as untracked per operator policy)
output/

# Codex CLI harness mirror — operator experiment, NOT a maintained artifact (operator call, 2026-07-13 S12).
# It appeared untracked on 2026-07-13 as a full parallel port of the harness (~42 agents, 19 hooks, its own
# check-foreign-staging.sh) and was NOT gitignored, so any broad `git add` would have swept ~60 files into
# the repo. It also carries its own copy of the /lean-repo Q3 orphan lens, which is NOT kept in sync with
# the canonical fix (id-55) — a third copy nobody maintains is exactly the drift this repo keeps paying for.
# Ignored so it cannot be committed by accident. If Codex is ever adopted for real, the decision to track
# and sync this mirror is a deliberate one to make — not an outcome of a wildcard staging command.
.codex/
.agents/
AGENTS.md
