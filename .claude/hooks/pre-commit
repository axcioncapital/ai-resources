#!/bin/bash
# Pre-commit hook: validates skill files before allowing a commit
# Install: copy to .git/hooks/pre-commit and make executable
# Or: create .claude/hooks/pre-commit and Claude Code picks it up

set -e

errors=0

# ===== Commit-boundary integrity guards — run on EVERY commit, before the SKILL.md early exit =====

# Guard 1: unresolved conflict markers.
# Block the UNAMBIGUOUS markers only — <<<<<<<, >>>>>>>, ||||||| . `=======` is DELIBERATELY
# EXCLUDED: it collides with Markdown setext headings and ==== dividers, and every real git
# conflict also emits <<<<<<< and >>>>>>>, so those catch it anyway. Anchored at line-start with
# a trailing space-or-EOL, so a marker mentioned mid-line or inside backticks is immune.
conflict_markers=$(git diff --cached -U0 | grep -E '^\+(<{7}|>{7}|\|{7})( |$)' || true)
if [ -n "$conflict_markers" ]; then
    echo "BLOCKED: staged content contains unresolved conflict markers:" >&2
    git diff --cached --name-only -G'^(<{7}|>{7}|\|{7})( |$)' >&2
    echo "  Resolve the conflict, or use 'git commit --no-verify' if the marker is intentional." >&2
    exit 1
fi

# Guard 2: append-order for newest-last logs (prevents a prepended entry shipping in a
# mid-session commit — the recorded failure, c3d5fe7). Delegates to check-append-order.sh,
# resolved from the repo root so it works from both the tracked and the installed hook copy.
ao_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
ao_script="${ao_root}/logs/scripts/check-append-order.sh"
if [ -n "$ao_root" ] && [ -x "$ao_script" ]; then
    ao_fail=0
    while IFS='|' read -r ao_path ao_re; do
        [ -n "$ao_path" ] || continue
        if git diff --cached --name-only --diff-filter=ACM | grep -Fxq "$ao_path"; then
            bash "$ao_script" "$ao_path" "$ao_re" || ao_fail=1
        fi
    done <<'AO_LOGS'
logs/session-notes.md|^## [0-9]{4}-[0-9]{2}-[0-9]{2}
logs/decisions.md|^## [0-9]{4}-[0-9]{2}-[0-9]{2}
logs/usage-log.md|^### [0-9]{4}-[0-9]{2}-[0-9]{2}
AO_LOGS
    if [ "$ao_fail" -ne 0 ]; then
        echo "  Append-order check failed. Fix the ordering, or 'git commit --no-verify' to override." >&2
        exit 1
    fi
fi

# ===== end integrity guards =====

echo "Running skill validation..."

# Find all SKILL.md files staged for commit
staged_skills=$(git diff --cached --name-only --diff-filter=ACM | grep "SKILL.md$" || true)

if [ -z "$staged_skills" ]; then
    echo "No SKILL.md files in this commit. Skipping skill validation."
    exit 0
fi

for skill_file in $staged_skills; do
    skill_dir=$(dirname "$skill_file")
    skill_name=$(basename "$skill_dir")

    echo ""
    echo "Checking: $skill_file"

    # --- Check 1: Folder naming convention (lowercase, hyphenated) ---
    if [[ ! "$skill_name" =~ ^[a-z0-9]([a-z0-9-]*[a-z0-9])?$ ]]; then
        echo "  FAIL: Folder name '$skill_name' must be lowercase and hyphenated"
        errors=$((errors + 1))
    fi

    # --- Check 2: YAML frontmatter exists ---
    first_line=$(head -n 1 "$skill_file")
    if [ "$first_line" != "---" ]; then
        echo "  FAIL: Missing YAML frontmatter (file must start with ---)"
        errors=$((errors + 1))
        continue  # Can't check further without frontmatter
    fi

    # --- Check 3: Frontmatter closes ---
    closing_line=$(tail -n +2 "$skill_file" | grep -n "^---$" | head -1 | cut -d: -f1)
    if [ -z "$closing_line" ]; then
        echo "  FAIL: Unclosed YAML frontmatter (missing closing ---)"
        errors=$((errors + 1))
        continue
    fi

    # Extract frontmatter content
    frontmatter=$(head -n $((closing_line + 1)) "$skill_file" | tail -n +2 | head -n $((closing_line - 1)))

    # --- Check 4: Required fields ---
    if ! echo "$frontmatter" | grep -q "^name:"; then
        echo "  FAIL: Missing 'name' field in frontmatter"
        errors=$((errors + 1))
    fi

    if ! echo "$frontmatter" | grep -q "^description:"; then
        echo "  FAIL: Missing 'description' field in frontmatter"
        errors=$((errors + 1))
    fi

    # --- Check 5: Description not empty ---
    desc_value=$(echo "$frontmatter" | grep "^description:" | sed 's/^description:\s*//')
    if [ -z "$desc_value" ] || [ "$desc_value" = "''" ] || [ "$desc_value" = '""' ]; then
        echo "  FAIL: Description field is empty"
        errors=$((errors + 1))
    fi

    # --- Check 6: No prohibited files ---
    for prohibited in "README.md" "CHANGELOG.md" "INSTALLATION_GUIDE.md" "QUICK_REFERENCE.md"; do
        if git diff --cached --name-only | grep -q "^$skill_dir/$prohibited$"; then
            echo "  FAIL: Prohibited file '$prohibited' staged for commit"
            errors=$((errors + 1))
        fi
    done

    echo "  Done."
done

echo ""
if [ $errors -gt 0 ]; then
    echo "BLOCKED: $errors error(s) found. Fix before committing."
    exit 1
fi

# Informational skill-size check (non-blocking, exit 0 even on warnings).
#
# Resolve the companion script from the REPO ROOT, not from $(dirname "$0").
# This hook runs from two different locations: the tracked source at
# .claude/hooks/pre-commit, and the INSTALLED copy at .git/hooks/pre-commit.
# A $(dirname "$0") lookup resolves to .git/hooks/ when installed — where
# check-skill-size.sh does not exist — so the check silently no-ops and the
# hook still reports success. Anchoring to the repo root works from both.
# (Caught by /risk-check, 2026-07-12: the sync that restored this call would
# otherwise have achieved nothing, and a "does the commit succeed?" test would
# have passed with the bug live.)
# The `|| true` is LOAD-BEARING, not defensive noise. This script runs under
# `set -e` (line 6). A bare assignment takes the exit status of its command
# substitution, so a failing `git rev-parse` (bare repo, GIT_DIR without a
# worktree) would abort the hook with exit 128 and BLOCK THE COMMIT — the exact
# opposite of this check's non-blocking contract, and it would do so before the
# `-n` guard below could ever run. Do not remove it.
repo_root="$(git rev-parse --show-toplevel 2>/dev/null || true)"
size_check="${repo_root}/.claude/hooks/check-skill-size.sh"
if [ -n "$repo_root" ] && [ -x "$size_check" ]; then
    "$size_check" || true
fi

echo "All skill checks passed."
exit 0
