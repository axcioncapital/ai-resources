{
  "permissions": {
    "allow": [
      "Bash(*)",
      "Read",
      "Edit",
      "Write",
      "MultiEdit",
      "Agent",
      "Skill",
      "TodoWrite",
      "Glob",
      "Grep",
      "WebFetch",
      "WebSearch",
      "NotebookEdit",
      "ToolSearch",
      "Edit(**/.claude/**)",
      "Write(**/.claude/**)",
      "Bash(rm *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Read(archive/**)",
      "Read(logs/*-archive-*.md)",
      "Read(inbox/archive/**)",
      "Read(**/deprecated/**)",
      "Read(**/old/**)",
      "Read(logs/*archive*.md)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "MAX_THINKING_TOKENS": "10000",
    "CLAUDE_AUTOCOMPACT_PCT_OVERRIDE": "80"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-heavy-tool.sh\"",
            "timeout": 5,
            "statusMessage": "Heavy-tool check..."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/friction-log-auto.sh\"",
            "timeout": 5,
            "statusMessage": "Checking friction log..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/log-write-activity.sh\"",
            "timeout": 5,
            "statusMessage": "Logging write activity..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-qc-nudge.sh\"",
            "timeout": 5,
            "statusMessage": "Checking for significant artifact writes..."
          }
        ]
      },
      {
        "matcher": "Bash|Write|Edit|Agent|Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/friction-log-auto.sh\"",
            "timeout": 5,
            "statusMessage": "Friction-event check..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-stop-reminders.sh\"",
            "timeout": 5,
            "statusMessage": "Checking session-end reminders..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/coach-reminder.sh\"",
            "timeout": 5,
            "statusMessage": "Checking coach reminder..."
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/improve-reminder.sh\"",
            "timeout": 5,
            "statusMessage": "Checking improve reminder..."
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/auto-resolve-nudge.sh\"",
            "timeout": 5,
            "statusMessage": "Checking for QC findings to resolve..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/friday-checkup-reminder.sh\"",
            "timeout": 5,
            "statusMessage": "Checking Friday cadence..."
          }
        ]
      }
    ]
  }
}
