{
  "permissions": {
    "allow": [
      "Edit(.claude/settings.json)",
      "Write(.claude/settings.json)",
      "Edit(**/.claude/settings.json)",
      "Write(**/.claude/settings.json)",
      "Edit",
      "Write",
      "MultiEdit",
      "Edit(.claude/**)",
      "Write(.claude/**)",
      "Edit(**/.claude/**)",
      "Write(**/.claude/**)",
      "Edit(**/.claude)",
      "Write(**/.claude)",
      "Edit(/Users/patrik.lindeberg/Claude Code/Axcion AI Repo/**)",
      "Write(/Users/patrik.lindeberg/Claude Code/Axcion AI Repo/**)",
      "Edit(logs/**)",
      "Write(logs/**)",
      "Edit(audits/**)",
      "Write(audits/**)",
      "Edit(skills/**)",
      "Write(skills/**)",
      "Edit(workflows/**)",
      "Write(workflows/**)",
      "Edit(prompts/**)",
      "Write(prompts/**)",
      "Edit(docs/**)",
      "Write(docs/**)",
      "Edit(scripts/**)",
      "Write(scripts/**)",
      "Edit(reports/**)",
      "Write(reports/**)",
      "Edit(inbox/**)",
      "Write(inbox/**)",
      "Edit(CLAUDE.md)",
      "Write(CLAUDE.md)",
      "Bash(*)",
      "Bash(rm *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git restore *)",
      "Bash(chmod *)",
      "Bash(mkdir *)",
      "Bash(cp *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(sudo *)",
      "Bash(git push*)",
      "Read(archive/**)",
      "Read(audits/working/**)",
      "Read(logs/*-archive-*.md)",
      "Read(inbox/archive/**)",
      "Read(**/deprecated/**)",
      "Read(**/old/**)"
    ],
    "defaultMode": "bypassPermissions"
  },
  "env": {
    "MAX_THINKING_TOKENS": "10000"
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Read|Grep|Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/check-heavy-tool.sh",
            "timeout": 5,
            "statusMessage": "Heavy-tool check..."
          }
        ]
      },
      {
        "matcher": "Skill",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/friction-log-auto.sh",
            "timeout": 5,
            "statusMessage": "Checking friction log..."
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/log-write-activity.sh",
            "timeout": 5,
            "statusMessage": "Logging write activity..."
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/coach-reminder.sh",
            "timeout": 5,
            "statusMessage": "Checking coach reminder..."
          },
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/improve-reminder.sh",
            "timeout": 5,
            "statusMessage": "Checking improve reminder..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/check-stop-reminders.sh",
            "timeout": 5,
            "statusMessage": "Checking session-end reminders..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash $CLAUDE_PROJECT_DIR/.claude/hooks/friday-checkup-reminder.sh",
            "timeout": 5,
            "statusMessage": "Checking Friday cadence..."
          }
        ]
      }
    ]
  }
}
